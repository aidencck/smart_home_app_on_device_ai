# 项目基础配置
PROJECT_NAME="SmartHome Edge-Cloud API"
VERSION="1.0.0"

# PostgreSQL 数据库配置
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smarthome_db
POSTGRES_PORT=5432

# Redis 缓存与设备影子配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# 安全与认证
# 生产环境必须替换此 KEY
SECRET_KEY="super-secret-key-change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# AI 大模型服务 (兜底路由配置)
# 可选: openai, vllm 兼容端点
AI_API_BASE="http://your-vllm-server:8000/v1"
AI_API_KEY="sk-your-api-key"
